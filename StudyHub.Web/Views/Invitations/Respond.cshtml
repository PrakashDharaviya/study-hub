@model StudyHub.Web.Models.Notifications.InvitationViewModel
@{
    ViewData["Title"] = "Group Invitation";
}

<div class="d-flex justify-content-center align-items-center flex-grow-1 py-4 py-md-5">
    <div class="w-100" style="max-width: 540px;">
        
        <!-- Back Navigation -->
        <div class="mb-4 ps-2">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-inline-flex align-items-center fw-medium" style="color: var(--text-muted); transition: color 0.2s ease;">
                <i data-lucide="arrow-left" class="me-2" style="width: 18px; height: 18px;"></i> Back to Home
            </a>
        </div>

        <!-- Neumorphic Card -->
        <div class="neu-card text-center">
            
            <!-- Icon + Heading -->
            <div class="card-icon mx-auto mb-4" style="color: var(--accent);">
                <i data-lucide="mail-open"></i>
            </div>
            <h2 class="mb-2 text-accent-dark">You're Invited!</h2>
            <p class="mb-4" style="color: var(--text-muted); font-size: 1.05rem;">
                <strong style="color: var(--text-main);">@Model.InviterName</strong> has invited you to join their study group.
            </p>

            <!-- Group Details Box -->
            <div class="p-4 mb-4 rounded-4 text-center" style="background-color: rgba(96, 108, 56, 0.05); border: 1px solid rgba(96, 108, 56, 0.1);">
                <div class="d-flex justify-content-center mb-2">
                    <i data-lucide="users" style="width: 24px; height: 24px; color: var(--accent);"></i>
                </div>
                <h4 class="fw-bold text-accent-dark mb-1">@Model.GroupName</h4>
                <small style="color: var(--text-muted);">Invitation sent @Model.TimeAgo</small>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-2">
                <!-- Decline Form -->
                <form asp-action="Decline" asp-route-id="@Model.InvitationId" method="post" class="w-100">
                    <button type="submit" class="neu-btn w-100 py-3" style="color: var(--danger); box-shadow: var(--shadow-in);">
                        Decline
                    </button>
                </form>
                
                <!-- Accept Form -->
                <form asp-action="Accept" asp-route-id="@Model.InvitationId" method="post" class="w-100">
                    <button type="submit" class="neu-btn w-100 py-3" style="color: var(--accent-dark);">
                        Accept Invitation
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>
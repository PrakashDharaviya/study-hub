@using Microsoft.AspNetCore.Identity
@using StudyHub.Web.Data.Entities
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Home";
}

<div class="container py-5">
    
    <!-- Hero Section -->
    <div class="row justify-content-center text-center mb-5 pb-4 mt-4">
        <div class="col-lg-9 col-xl-8">
            
            <!-- Neumorphic Hero Icon -->
            <div class="d-inline-flex align-items-center justify-content-center p-4 rounded-circle mb-4" style="background-color: var(--bg); box-shadow: var(--shadow-out); color: var(--accent);">
                <i data-lucide="library" style="width: 56px; height: 56px;"></i>
            </div>
            
            <h1 class="display-4 fw-bold text-accent-dark mb-4" style="letter-spacing: -0.03em; line-height: 1.1;">
                Organized minds.<br />Shared knowledge.
            </h1>
            
            <p class="lead mb-5 mx-auto" style="color: var(--text-muted); font-size: 1.25rem; max-width: 700px;">
                StudyHub consolidates group creation, resource sharing, and academic collaboration into one clean, focused platform. Say goodbye to fragmented chats.
            </p>
            
            <!-- Dynamic Call-To-Action Buttons -->
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Groups" asp-action="Index" class="neu-btn px-5 py-3 fs-5 d-inline-flex align-items-center justify-content-center">
                        Discover Groups <i data-lucide="arrow-right" class="ms-2" style="width: 20px; height: 20px;"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="neu-btn px-5 py-3 fs-5">
                        Get Started
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="neu-btn px-5 py-3 fs-5" style="box-shadow: var(--shadow-in); color: var(--text-muted);">
                        Log In
                    </a>
                }
            </div>
            
        </div>
    </div>

    <!-- Features Section -->
    <div class="row row-cols-1 row-cols-md-3 g-4 mt-2 mb-5">
        
        <!-- Feature 1 -->
        <div class="col">
            <div class="neu-card h-100 text-center p-4 p-lg-5">
                <div class="card-icon mx-auto mb-4" style="width: 64px; height: 64px;">
                    <i data-lucide="users" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="text-accent-dark mb-3">Structured Groups</h4>
                <p class="mb-0" style="color: var(--text-muted); font-size: 0.95rem;">
                    Create or join study groups tailored to your specific courses, semesters, and topics. Keep your academic circles organized.
                </p>
            </div>
        </div>
        
        <!-- Feature 2 -->
        <div class="col">
            <div class="neu-card h-100 text-center p-4 p-lg-5">
                <div class="card-icon mx-auto mb-4" style="width: 64px; height: 64px;">
                    <i data-lucide="folder-open" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="text-accent-dark mb-3">Resource Library</h4>
                <p class="mb-0" style="color: var(--text-muted); font-size: 0.95rem;">
                    Upload PDFs, share important links, and pin crucial documents. Build a centralized knowledge base for every class.
                </p>
            </div>
        </div>
        
        <!-- Feature 3 -->
        <div class="col">
            <div class="neu-card h-100 text-center p-4 p-lg-5">
                <div class="card-icon mx-auto mb-4" style="width: 64px; height: 64px;">
                    <i data-lucide="search" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="text-accent-dark mb-3">Easy Discovery</h4>
                <p class="mb-0" style="color: var(--text-muted); font-size: 0.95rem;">
                    Filter groups by semester or search by topic tags. Finding the right study partners has never been this seamless.
                </p>
            </div>
        </div>
        
    </div>
</div>
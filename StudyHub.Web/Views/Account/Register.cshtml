@model StudyHub.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Sign Up";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6 col-xl-5">
        <div class="sh-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i data-lucide="user-plus" class="text-primary mb-3" style="width: 48px; height: 48px;"></i>
                <h2 class="fw-bold">Create an Account</h2>
                <p class="text-muted">Join StudyHub to organize and share knowledge.</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label fw-bold"></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Jane" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label fw-bold"></label>
                        <input asp-for="LastName" class="form-control" placeholder="Doe" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" class="form-control" placeholder="name@university.edu" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold"></label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 mb-3">Sign Up</button>

                <div class="text-center">
                    <span class="text-muted">Already have an account?</span>
                    <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold text-primary">Log in</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model StudyHub.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Sign Up";
}

<div class="auth-wrapper">
    <div class="w-100" style="max-width: 480px;">

        <!-- Neumorphic Card -->
        <div class="neu-card">

            <!-- Icon + Heading -->
            <div class="text-center mb-4">
                <div class="card-icon">
                    <i data-lucide="user-plus"></i>
                </div>
                <h2 class="mb-1">Create Account</h2>
                <p class="mb-0" style="color: var(--text-muted); font-size: 0.92rem;">
                    Join StudyHub to organise and share knowledge.
                </p>
            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <form asp-controller="Account" asp-action="Register" method="post" novalidate>

                <!-- First + Last Name row -->
                
                <div class="row g-3 mb-3">
                    <div class="col-12 col-sm-6">
                        <label asp-for="FirstName" class="form-label">First Name</label>
                        <input asp-for="FirstName"
                               class="neu-input"
                               placeholder="Jane"
                               autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="LastName" class="form-label">Last Name</label>
                        <input asp-for="LastName"
                               class="neu-input"
                               placeholder="Doe"
                               autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email"
                           class="neu-input"
                           type="email"
                           placeholder="name@university.edu"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password"
                           class="neu-input"
                           type="password"
                           placeholder="••••••••"
                           autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Confirm Password -->
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword"
                           class="neu-input"
                           type="password"
                           placeholder="••••••••"
                           autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <!-- Submit -->
                <button type="submit" class="neu-btn w-100 py-3 mb-3" style="font-size: 0.97rem;">
                    Sign Up
                </button>

                <!-- Login link -->
                <p class="text-center mb-0" style="font-size: 0.9rem;">
                    <span style="color: var(--text-muted);">Already have an account?</span>
                    <a asp-controller="Account" asp-action="Login"
                       class="fw-bold ms-1" style="color: var(--accent);">Log in</a>
                </p>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model StudyHub.Web.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "Log In";
}


<div class="auth-wrapper">
    <div class="w-100" style="max-width: 420px;">

        <!-- Neumorphic Card -->
        <div class="neu-card">

            <!-- Icon + Heading -->
            <div class="text-center mb-4">
                <div class="card-icon">
                    <i data-lucide="log-in"></i>
                </div>
                <h2 class="mb-1">Welcome Back</h2>
                <p class="mb-0" style="color: var(--text-muted); font-size: 0.92rem;">
                    Log in to access your study groups.
                </p>
            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <form asp-controller="Account" asp-action="Login"
                  asp-route-returnUrl="@ViewData["ReturnUrl"]"
                  method="post" novalidate>

                <!-- Email -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email"
                           class="neu-input"
                           type="email"
                           placeholder="name@university.edu"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password"
                           class="neu-input"
                           type="password"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Remember Me — fixed alignment with .checkbox-row -->
                <div class="mb-4">
                    <label class="checkbox-row">
                        <input asp-for="RememberMe" class="neu-checkbox" />
                        <span style="color: var(--text-muted); font-weight: 500; font-size: 0.9rem;">Remember me?</span>
                    </label>
                </div>

                <!-- Submit -->
                <button type="submit" class="neu-btn w-100 py-3 mb-3" style="font-size: 0.97rem;">
                    Log In
                </button>

                <!-- Register link -->
                <p class="text-center mb-0" style="font-size: 0.9rem;">
                    <span style="color: var(--text-muted);">Don't have an account?</span>
                    <a asp-controller="Account" asp-action="Register"
                       class="fw-bold ms-1" style="color: var(--accent);">Sign up</a>
                </p>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

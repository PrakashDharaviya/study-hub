@model StudyHub.Web.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "Log In";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6 col-xl-4">
        <div class="sh-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i data-lucide="log-in" class="text-primary mb-3" style="width: 48px; height: 48px;"></i>
                <h2 class="fw-bold">Welcome Back</h2>
                <p class="text-muted">Log in to access your study groups.</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" class="form-control" placeholder="name@university.edu" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-bold"></label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 mb-3">Log In</button>

                <div class="text-center">
                    <span class="text-muted">Don't have an account?</span>
                    <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-primary">Sign up</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
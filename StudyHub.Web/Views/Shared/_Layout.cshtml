@using Microsoft.AspNetCore.Identity
@using StudyHub.Web.Data.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyHub</title>

    <!-- Bootstrap 5.3 (Local) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Earthy Minimalist Design System -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudyHub.Web.styles.css" asp-append-version="true" />

    <!-- Lucide Icons (CDN) -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

    <!-- ===== GLASSMORPHISM NAVBAR ===== -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light glass-nav py-3">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i data-lucide="library"></i> StudyHub
                </a>

                <!-- Mobile Toggler -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav Links -->
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <!-- Left: page links -->
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <!-- Always visible -->
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Groups" asp-action="Index">Discover Groups</a>
                        </li>
                        
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <!-- NEW: My Groups Link for all logged-in users -->
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Groups" asp-action="MyGroups">My Groups</a>
                            </li>

                            <!-- SECURED: Admin Panel Link only for PlatformAdmin -->
                            @if (User.IsInRole("PlatformAdmin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-1" asp-area="" asp-controller="Admin" asp-action="Index" style="color: var(--accent);">
                                        <i data-lucide="shield-check" style="width: 16px; height: 16px;"></i> Admin
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- Right: auth links -->
                    <ul class="navbar-nav align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <span class="nav-link d-flex align-items-center gap-2 pe-none" style="color: var(--text-muted);">
                                    <i data-lucide="user" style="width:17px;height:17px;"></i>
                                    @User.Identity?.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form class="m-0" asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="neu-btn py-2 px-4" style="font-size:0.88rem;">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" asp-controller="Account" asp-action="Login">Log in</a>
                            </li>
                            <li class="nav-item">
                                <a class="neu-btn py-2 px-4" asp-controller="Account" asp-action="Register" style="font-size:0.88rem;">Sign up</a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- ===== MAIN CONTENT WRAPPER (flex-grow pushes footer down) ===== -->
    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ===== FOOTER (always at bottom, never overlaps) ===== -->
    <footer class="site-footer">
        <div class="container">
            &copy; @DateTime.Now.Year &ndash; StudyHub &ndash;
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Initialize Lucide Icons AFTER DOM is ready -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
        lucide.createIcons();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
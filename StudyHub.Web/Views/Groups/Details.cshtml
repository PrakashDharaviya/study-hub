@model StudyHub.Web.Models.Groups.GroupDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="page-wrapper py-4 py-md-5">
    <div class="container">
        
        <!-- Back Navigation -->
        <div class="mb-4 ps-2">
            <a asp-action="Index" class="text-decoration-none d-inline-flex align-items-center fw-medium" style="color: var(--text-muted);">
                <i data-lucide="arrow-left" class="me-2" style="width: 18px; height: 18px;"></i> Back to Discover
            </a>
        </div>

        <!-- Main Group Header Card -->
        <div class="neu-card mb-5">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-4">
                <div>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <h1 class="mb-0 text-accent-dark">@Model.Name</h1>
                        <span class="badge rounded-pill" style="background-color: rgba(96, 108, 56, 0.1); color: var(--accent); border: 1px solid rgba(96, 108, 56, 0.2); font-weight: 600; padding: 0.5em 1em;">
                            @Model.Semester
                        </span>
                    </div>
                    <p class="mb-3" style="color: var(--text-muted); font-size: 1.05rem;">@Model.Description</p>
                    
                    @if (!string.IsNullOrWhiteSpace(Model.TopicTags))
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var tag in Model.TopicTags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge rounded-pill" style="background-color: var(--bg); color: var(--text-muted); border: 1px solid rgba(40, 54, 24, 0.1); font-weight: 500;">
                                    <i data-lucide="tag" class="me-1" style="width: 12px; height: 12px;"></i> @tag.Trim()
                                </span>
                            }
                        </div>
                    }
                </div>

                <div class="text-md-end">
                    @if (!Model.IsCurrentUserMember)
                    {
                        <form asp-action="Join" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="neu-btn py-2 px-4">
                                <i data-lucide="user-plus" class="me-2" style="width: 18px; height: 18px;"></i> Join Group
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="d-inline-flex align-items-center px-4 py-2 rounded-3" style="background-color: rgba(96, 108, 56, 0.1); color: var(--accent); border: 1px solid rgba(96, 108, 56, 0.2); font-weight: 600;">
                            <i data-lucide="check-circle" class="me-2" style="width: 18px; height: 18px;"></i> Member
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Tabs for Resources and Members -->
        <ul class="nav nav-pills mb-4 gap-2" id="groupTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="neu-btn active" id="resources-tab" data-bs-toggle="tab" data-bs-target="#resources" type="button" role="tab" aria-controls="resources" aria-selected="true" style="padding: 10px 20px;">
                    <i data-lucide="folder" class="me-2" style="width: 16px; height: 16px;"></i> Resources
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="neu-btn" id="members-tab" data-bs-toggle="tab" data-bs-target="#members" type="button" role="tab" aria-controls="members" aria-selected="false" style="padding: 10px 20px;">
                    <i data-lucide="users" class="me-2" style="width: 16px; height: 16px;"></i> Members (@Model.Members.Count)
                </button>
            </li>
        </ul>

        <div class="tab-content" id="groupTabsContent">
            
            <!-- RESOURCES TAB -->
            <div class="tab-pane fade show active" id="resources" role="tabpanel" aria-labelledby="resources-tab">
                <div class="neu-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="text-accent-dark mb-0">Shared Resources</h3>
                        @if (Model.IsCurrentUserMember)
                        {
                            <button class="neu-btn py-2 px-3" style="font-size: 0.85rem;">
                                <i data-lucide="upload" class="me-1" style="width: 16px; height: 16px;"></i> Add Resource
                            </button>
                        }
                    </div>

                    @if (!Model.IsCurrentUserMember)
                    {
                        <div class="text-center py-5">
                            <i data-lucide="lock" class="mb-3" style="width: 48px; height: 48px; color: var(--text-muted);"></i>
                            <h4 class="text-accent-dark">Members Only</h4>
                            <p style="color: var(--text-muted);">You must join this group to view and share resources.</p>
                        </div>
                    }
                    else if (!Model.Resources.Any())
                    {
                        <div class="text-center py-5">
                            <i data-lucide="file-question" class="mb-3" style="width: 48px; height: 48px; color: var(--text-muted);"></i>
                            <h4 class="text-accent-dark">No resources yet</h4>
                            <p style="color: var(--text-muted);">Be the first to share a link or document with the group!</p>
                        </div>
                    }
                    else
                    {
                        <!-- Resource List will go here in the next module -->
                        <p>Resources will be displayed here.</p>
                    }
                </div>
            </div>

            <!-- MEMBERS TAB -->
            <div class="tab-pane fade" id="members" role="tabpanel" aria-labelledby="members-tab">
                <div class="neu-card">
                    <h3 class="text-accent-dark mb-4">Group Members</h3>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                        @foreach (var member in Model.Members)
                        {
                            <div class="col">
                                <div class="d-flex align-items-center p-3 rounded-4" style="border: 1px solid rgba(40, 54, 24, 0.1); background-color: rgba(255,255,255,0.3);">
                                    <div class="d-flex align-items-center justify-content-center rounded-circle me-3" style="width: 40px; height: 40px; background-color: var(--bg); box-shadow: var(--shadow-out-sm); color: var(--accent);">
                                        <i data-lucide="user" style="width: 20px; height: 20px;"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 text-accent-dark fw-bold">@member.FullName</h6>
                                        <small style="color: var(--text-muted);">
                                            @if (member.Role == "Admin")
                                            {
                                                <span class="badge bg-transparent p-0 text-accent me-1"><i data-lucide="shield" style="width: 12px; height: 12px;"></i> Admin</span>
                                            }
                                            Joined @member.JoinedAt.ToString("MMM dd, yyyy")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>